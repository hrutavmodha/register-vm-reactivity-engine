{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "paths": {
      "driftjs": ["./packages/core/src/index.ts"],
      "driftjs/*": ["./packages/core/src/*"],
      "vite-plugin-drift": ["./packages/vite-plugin/src/index.ts"]
    },

    // Environment Settings
    "module": "nodenext",
    "target": "esnext",
    "types": [],

    // Other Outputs
    "noEmit": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
